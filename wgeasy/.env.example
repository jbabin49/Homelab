# wg-easy — Variables d'environnement
# Copier en .env et adapter les valeurs.

# IP publique ou domaine pointant vers le serveur WireGuard
WG_HOST=CHANGE_ME_PUBLIC_IP_OR_DOMAIN

# Hash bcrypt du mot de passe admin (générer avec : htpasswd -nbBC 10 "" 'motdepasse' | cut -d: -f2)
PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH

# IP du serveur DNS pour les clients VPN (ex: AdGuard Home)
WG_DEFAULT_DNS=CHANGE_ME_ADGUARD_IP

# Sous-réseaux accessibles via le tunnel
WG_ALLOWED_IPS=192.168.1.0/24

# Langue de l'interface
LANG=fr
