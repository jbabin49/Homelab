  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 9000,
      "title": "Server 1",
      "type": "row"
    },
    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "0=cadvisor down, 1=containers running, 2=cadvisor down",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "Down"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "Running"
                },
                "2": {
                  "color": "orange",
                  "index": 2,
                  "text": "cAdvisor only"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 1101,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "text": {
          "titleSize": 28,
          "valueSize": 28
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "refId": "A",
          "range": true,
          "expr": "(1 - (up{instance=\"10.0.0.X1:8080\"} or on() vector(0))) * 2 + (((count(container_last_seen{instance=\"10.0.0.X1:8080\",id=~\"/system.slice/docker-.*\\\\.scope\"}) > bool 0) or on() vector(0)) * (up{instance=\"10.0.0.X1:8080\"} or on() vector(0)))",
          "legendFormat": "State"
        }
      ],
      "title": "Name",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 6,
        "y": 1
      },
      "id": 1102,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "refId": "A",
          "range": true,
          "expr": "sum(rate(container_cpu_usage_seconds_total{instance=\"10.0.0.X1:8080\",id=~\"/system.slice/docker-.*\\\\.scope\"}[5m])) * 100",
          "legendFormat": "CPU"
        }
      ],
      "title": "CPU",
      "type": "timeseries"
    },
    {
