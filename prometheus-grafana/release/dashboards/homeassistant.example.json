          "instant": true,
          "range": false,
          "expr": "avg by (job, entity) (homeassistant_climate_current_temperature_celsius{job=\"homeassistant\",entity=\"$climate_entity\"}) and on(job, entity) (avg by (job, entity) (homeassistant_climate_current_temperature_celsius{job=\"homeassistant\",entity=\"$climate_entity\"}) < (avg by (job, entity) (homeassistant_climate_target_temperature_celsius{job=\"homeassistant\",entity=\"$climate_entity\"}) - 1.5))",
