{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Server CPU usage",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$node_instance\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Docker daemon status",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "sum(up{instance=~\"$docker_daemon_instance\"})",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Containers resource usage",
      "type": "table",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "topk(5, sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\",instance=~\"$cadvisor_instance\"}[5m])) * 100)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "topk(5, sum by (name) (container_memory_working_set_bytes{name!=\"\",instance=~\"$cadvisor_instance\"}))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "HA devices connected / available",
      "type": "table",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_device_tracker_state{job=\"$ha_job\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_entity_available{job=\"$ha_job\",entity=~\"device_tracker\\..*\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "entity",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "Value": "Connected",
              "Value 1": "Available"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "HA switch example",
      "type": "bargauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OFF",
                  "color": "red"
                },
                "1": {
                  "text": "ON",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_switch_state{job=\"$ha_job\"}",
          "legendFormat": "{{entity}}",
          "range": true
        }
      ]
    },
    {
      "id": 6,
      "title": "HA climate / sensor / binary sensor examples",
      "type": "table",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_climate_current_temperature_celsius{job=\"$ha_job\",entity=\"$ha_climate_entity\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_climate_target_temperature_celsius{job=\"$ha_job\",entity=\"$ha_climate_entity\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_sensor_temperature_celsius{job=\"$ha_job\",entity=\"$ha_temperature_sensor\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_binary_sensor_state{job=\"$ha_job\",entity=\"$ha_binary_sensor\"}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "HA energy daily example",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_sensor_energy_kwh{job=\"$ha_job\",entity=\"$ha_daily_energy_sensor\"}",
          "legendFormat": "Current",
          "range": true
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_sensor_energy_kwh{job=\"$ha_job\",entity=\"$ha_daily_energy_sensor\"} offset 7d",
          "legendFormat": "Offset 7d",
          "range": true
        }
      ]
    },
    {
      "id": 8,
      "title": "HA energy monthly example",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_sensor_energy_kwh{job=\"$ha_job\",entity=\"$ha_monthly_energy_sensor\"}",
          "legendFormat": "Current",
          "range": true
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "homeassistant_sensor_energy_kwh{job=\"$ha_job\",entity=\"$ha_monthly_energy_sensor\"} offset 365d",
          "legendFormat": "Offset 365d",
          "range": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Missing critical metrics example",
      "type": "table",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "label_replace(absent(node_cpu_seconds_total{mode=\"idle\"}), \"missing_metric\", \"node_cpu_seconds_total\", \"\", \"\") or label_replace(absent(container_last_seen), \"missing_metric\", \"container_last_seen\", \"\", \"\") or label_replace(absent(homeassistant_device_tracker_state{job=\"$ha_job\"}), \"missing_metric\", \"homeassistant_device_tracker_state\", \"\", \"\")",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "Missing"
            }
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "example",
    "generic",
    "prometheus",
    "grafana",
    "homeassistant",
    "docker"
  ],
