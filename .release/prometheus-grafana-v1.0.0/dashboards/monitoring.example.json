    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "État UP/DOWN de chaque endpoint scrapé",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "up{job=~\"ha_node_exporter|ha_cadvisor|ha_docker|homeassistant\"}",
          "legendFormat": "{{job}} — {{instance}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Endpoints",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "victoriametrics-metrics-datasource",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Métriques critiques absentes (1 = manquante). Adaptez la liste à votre stack.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
                  "text": "OK"
                },
                "1": {
                  "color": "red",
                  "index": 1,
                  "text": "Missing"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-metrics-datasource",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A",
          "expr": "label_replace(absent(node_cpu_seconds_total{job=\"ha_node_exporter\",mode=\"idle\"}), \"missing_metric\", \"node_cpu_seconds_total\", \"\", \"\") or label_replace(absent(node_memory_MemAvailable_bytes{job=\"ha_node_exporter\"}), \"missing_metric\", \"node_memory_MemAvailable_bytes\", \"\", \"\") or label_replace(absent(node_filesystem_avail_bytes{job=\"ha_node_exporter\"}), \"missing_metric\", \"node_filesystem_avail_bytes\", \"\", \"\") or label_replace(absent(node_network_receive_bytes_total{job=\"ha_node_exporter\"}), \"missing_metric\", \"node_network_receive_bytes_total\", \"\", \"\") or label_replace(absent(container_last_seen{job=\"ha_cadvisor\"}), \"missing_metric\", \"container_last_seen\", \"\", \"\") or label_replace(absent(container_cpu_usage_seconds_total{job=\"ha_cadvisor\"}), \"missing_metric\", \"container_cpu_usage_seconds_total\", \"\", \"\") or label_replace(absent(container_memory_working_set_bytes{job=\"ha_cadvisor\"}), \"missing_metric\", \"container_memory_working_set_bytes\", \"\", \"\") or label_replace(absent(homeassistant_climate_current_temperature_celsius{job=\"homeassistant\"}), \"missing_metric\", \"ha_climate_temperature\", \"\", \"\") or label_replace(absent(homeassistant_switch_state{job=\"homeassistant\"}), \"missing_metric\", \"ha_switch_state\", \"\", \"\") or label_replace(absent(homeassistant_sensor_energy_kwh{job=\"homeassistant\"}), \"missing_metric\", \"ha_sensor_energy_kwh\", \"\", \"\")"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "missing_metric": 0,
              "Value": 1
            },
            "renameByName": {
              "Value": "Status"
            }
          }
        }
      ],
      "title": "Métriques manquantes",
      "type": "table"
    },
