# Home Assistant — secrets d'exemple
# Copier en secrets.yaml et renseigner les vraies valeurs.
# Ce fichier ne doit JAMAIS être committé.

# Free Mobile SMS
free_mobile_username: "<CHANGE_ME>"
free_mobile_token: "<CHANGE_ME>"

# Ntfy — token Bearer (sans guillemets supplémentaires !)
ntfy_ha_token: "Bearer <CHANGE_ME_TOKEN>"
